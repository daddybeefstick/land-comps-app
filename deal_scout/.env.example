RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=private-zillow.p.rapidapi.com
# Rate limit: min seconds between requests (default 0.5)
# MIN_SECONDS_BETWEEN_REQUESTS=0.5
# Enrichment: set to enable enrich_by_zpid (unconfirmed; leave unset for v1)
# ZILLOW_PROPERTY_BY_ZPID_ENDPOINT=/properties/detail
DATABASE_PATH=database/deals.db

# Optional: push review list to Google Sheet (sync_review_list_to_sheet.py)
# SHEETS_SPREADSHEET_ID=your_sheet_id_from_url
# SHEETS_SHEET_NAME=TX_Review_Queue
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
